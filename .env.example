# Session (required for nuxt-auth-utils, min 32 chars)
NUXT_SESSION_PASSWORD=your-session-password-at-least-32-characters-long

# Google OAuth (for Gmail login)
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# Optional: Mail SMTP (for nuxt-mail)
# NUXT_MAIL_SMTP_HOST=localhost
# NUXT_MAIL_SMTP_PORT=1025
# NUXT_MAIL_DEFAULT_TO=dev@localhost
